{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Procer",
  "scopeName": "source.procer",
  "fileTypes": ["procer", "prc"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#builtin-values" },
    { "include": "#keywords" },
    { "include": "#control-flow" },
    { "include": "#procedure-definition" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.double-slash.procer",
      "match": "//.*$"
    },
    "strings": {
      "name": "string.quoted.double.procer",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.procer",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.procer",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.procer",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "builtin-values": {
      "name": "constant.language.procer",
      "match": "\\b(true|false|null)\\b"
    },
    "keywords": {
      "patterns": [
        {
          "comment": "variable declaration",
          "name": "keyword.control.let.procer",
          "match": "\\blet\\b"
        },
        {
          "comment": "assignment verb",
          "name": "keyword.operator.assignment.procer",
          "match": "\\bbe\\b"
        },
        {
          "comment": "object method verbs",
          "name": "keyword.other.verb.procer",
          "match": "\\b(on|do|run)\\b"
        },
        {
          "comment": "property access",
          "name": "keyword.other.access.procer",
          "match": "\\bof\\b"
        },
        {
          "comment": "stop / return",
          "name": "keyword.control.stop.procer",
          "match": "\\b(stop|return|nothing)\\b"
        },
        {
          "comment": "block closer",
          "name": "keyword.control.done.procer",
          "match": "\\bdone\\b"
        },
        {
          "comment": "loop keywords",
          "name": "keyword.control.loop.procer",
          "match": "\\b(from|to|by|as|for|each|in|while|until)\\b"
        },
        {
          "comment": "signal handling",
          "name": "keyword.control.signal.procer",
          "match": "\\b(wait|for|signal|signals|all)\\b"
        },
        {
          "comment": "conditional keywords",
          "name": "keyword.control.conditional.procer",
          "match": "\\b(if|or|not)\\b"
        },
        {
          "comment": "existence check",
          "name": "keyword.other.exists.procer",
          "match": "\\bexists\\b"
        }
      ]
    },
    "control-flow": {
      "comment": "is / is not comparison operators written as words",
      "name": "keyword.operator.comparison.procer",
      "match": "\\b(is\\s+not|is)\\b"
    },
    "procedure-definition": {
      "comment": "procedure keyword and name",
      "patterns": [
        {
          "name": "storage.type.function.procer",
          "match": "\\bprocedure\\b"
        },
        {
          "comment": "procedure name following the keyword",
          "match": "(?<=procedure)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.procer" }
          }
        }
      ]
    },
    "function-call": {
      "comment": "identifier immediately followed by ( is a function call",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.procer" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.word.procer",
          "match": "\\b(and|or)\\b"
        },
        {
          "name": "keyword.operator.arithmetic.procer",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.symbol.procer",
          "match": "(!=|>=|<=|>|<|=)"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.procer",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.procer",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.comma.procer",
          "match": ","
        },
        {
          "name": "punctuation.definition.parameters.begin.procer",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.parameters.end.procer",
          "match": "\\)"
        }
      ]
    }
  }
}
